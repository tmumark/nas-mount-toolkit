# NAS 連線設定
# 複製此檔案為 nas_config 並填入你的資訊：
#   cp nas_config.example nas_config

SMB_SERVER="192.168.1.250"      # NAS IP 位址
SMB_USER="your_username"        # SMB 帳號
SMB_PASS='your_password'        # SMB 密碼

# 要掛載的共享資料夾（可自行增減）
SHARES=(
  "相片"
  "共用資料"
  "個人備份及公共區"
)

# 掛載完成後自動開啟的資料夾路徑（留空則不開啟）
AUTO_OPEN_PATH="/Volumes/個人備份及公共區/個人備份區/Mark"
